# OLLAMA_API_KEY: Required for Ollama/LLM API calls.
OLLAMA_API_KEY="MY_OLLAMA_API_KEY"

# OLLAMA_BASE_URL: The base URL for the Ollama API (OpenAI compatible).
# Example: https://your-ollama-host.com/v1
OLLAMA_BASE_URL="https://ollama.com/v1"

# OLLAMA_MODEL: The model name to use.
OLLAMA_MODEL="minimax-m2.7"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
